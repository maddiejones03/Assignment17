# Copy to .env.local and fill in. Required only when using Supabase (otherwise the app uses in-memory mock data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional. Overrides the fraud model HTTP endpoint used during "Run Scoring".
# On Vercel, defaults to https://$VERCEL_URL/api/ml_predict when unset.
# For local Python: run `vercel dev` or set to your deployed API URL.
# ML_PREDICT_URL=
